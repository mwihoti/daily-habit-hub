# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Web3 — Avalanche ──────────────────────────────────────────────────────────
# Contract addresses (Fuji testnet — replace with mainnet addresses for production)
NEXT_PUBLIC_HABIT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HABIT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ACHIEVEMENT_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect project ID — get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Admin wallet private key — NEVER commit the real value, use Vercel secrets
# Generate a fresh wallet for deployment: https://vanity-eth.tk/
PRIVATE_ADMIN_KEY=0x_your_admin_wallet_private_key

# ─── IPFS (Pinata) — optional ──────────────────────────────────────────────────
# Without these, workout metadata uses base64 data URIs (works, just not real IPFS)
# Get free keys at https://pinata.cloud
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key

# ─── Contract verification (optional) ─────────────────────────────────────────
# Get a free Snowtrace API key at https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=your-snowtrace-api-key
